    {
      "dot": "cyan",
      "title": "Core runtime",
      "items": [
        "LangGraph owns topology and resumability",
        "Stage Executor enforces tool vs agent execution",
        "Typed tools validate outputs before adapters"
      ]
    },
    {
      "dot": "emerald",
      "title": "D35 agent contract",
      "items": [
        "Persona runs before concepts",
        "Persona, concepts, scripts, video have own system prompts",
        "Catalog exposes path + has_system_prompt, not prompt text"
      ]
    },
    {
      "dot": "rose",
      "title": "Profiles and providers",
      "items": [
        "config/ uses live providers through role routing",
        "config-mock/ stays offline and deterministic",
        "External calls require env keys; LangSmith is optional"
      ]

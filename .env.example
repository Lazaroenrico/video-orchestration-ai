# ============================================================================
# .env.example — copie para `.env` e preencha suas chaves.
#   cp .env.example .env
#
# NUNCA faça commit do `.env` real (já está no .gitignore).
#
# Mapa: cada bloco abaixo corresponde a um passo do Context.md. Em v1 TUDO roda
# mock/dry-run e NADA aqui é necessário — o pipeline roda sem nenhuma chave. As
# variáveis abaixo só entram em ação conforme cada adapter real for plugado
# (ver "Como plugar um adapter real" no CLAUDE.md).
#
# Legenda:
#   [LIVE]   já lido pelo código hoje.
#   [FUTURO] reservado para quando o adapter real do passo for implementado.
# ============================================================================


# ----------------------------------------------------------------------------
# Steps 1, 2 e 7 — Claude via Vercel AI Gateway (conceitos, scripts e QC textual)
# Caminho recomendado para tráfego real: Vercel AI Gateway, inclusive para modelos da família Anthropic.
# ----------------------------------------------------------------------------
# [LIVE] adapter LLMPort via Vercel AI Gateway
AI_GATEWAY_API_KEY=
VERCEL_OIDC_TOKEN=
AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1
AI_GATEWAY_LLM_MODEL=anthropic/claude-opus-4.8
# Endpoint OpenAI-compatível do Gateway é .../v1 (NÃO .../openai/v1).
# Image-only models (GPT Image 2) usam {base}/images/generations.
AI_GATEWAY_OPENAI_BASE_URL=https://ai-gateway.vercel.sh/v1
# Model precisa do prefixo do provider no Gateway.
AI_GATEWAY_OPENAI_MODEL=openai/gpt-image-2

# Legado / backward-compatible — provider direto, não recomendado como caminho live do projeto.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8


# ----------------------------------------------------------------------------
# Step 3 — Creator reutilizável (rosto + upscale + voz)
# ----------------------------------------------------------------------------
# GPT Image 2 — geração do rosto/refs multi-ângulo via Vercel AI Gateway.
# Para MVP: use AI_GATEWAY_API_KEY (acima) — o endpoint /v1/images/generations do gateway
# roteia para GPT Image 2 (model openai/gpt-image-2). Resposta vem em base64 (b64_json).
# OPENAI_API_KEY só é necessário com o adapter direto "creator_real" (sem gateway).
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2

# Topaz — upscale da referência primária para base 4K limpa.
# [LIVE] lido por adapters/topaz_upscale.py via creator_real_vercel.
TOPAZ_API_KEY=

# ElevenLabs via Replicate — voz consistente por creator no perfil live atual
# (`creator_real_replicate`). Use um ref Replicate pinado (owner/model:version).
# [LIVE] lido por adapters/replicate_voice.py via creator_real_replicate.
REPLICATE_ELEVENLABS_MODEL=
REPLICATE_ELEVENLABS_TEXT_FIELD=text
REPLICATE_ELEVENLABS_VOICE_FIELD=voice_id
REPLICATE_ELEVENLABS_MODEL_ID_FIELD=model_id
REPLICATE_ELEVENLABS_MODEL_ID=
REPLICATE_ELEVENLABS_VOICE_ID=
REPLICATE_ELEVENLABS_VOICE_ID_FEMALE=
REPLICATE_ELEVENLABS_VOICE_ID_MALE=
REPLICATE_ELEVENLABS_VOICE_ID_NEUTRAL=
REPLICATE_ELEVENLABS_INPUT_JSON=

# ElevenLabs direto — legado/backward-compatible para `creator_real_vercel`.
# O caminho live normal deste projeto usa ElevenLabs hospedado no Replicate.
ELEVENLABS_API_KEY=


# ----------------------------------------------------------------------------
# Steps 4 e 5 — Geração de vídeo (talking-head + product demo)
# Tiers do artigo: LTX 2.3 ($0.01/s) -> Kling 3.0 ($0.10/s) -> Seedance 2.0 ($0.168/s)
# rodados DIRETO numa plataforma de geração, na sua própria chave.
# Escolha UMA plataforma (Replicate é a que já tem adapter no projeto).
# ----------------------------------------------------------------------------
# Replicate — [LIVE] já lido por adapters/replicate_video.py e registry.py.
# MVP: config/providers.yaml já usa `video: replicate`.
REPLICATE_API_TOKEN=

# Alternativas à Replicate (mesmo papel de VideoPort) — [FUTURO]
FAL_KEY=
ATLASCLOUD_API_KEY=


# ----------------------------------------------------------------------------
# Step 7 — LLM Judge via API Gateway (avaliação determinística do QC)
# [LIVE] lido por config/judge.yaml (${JUDGE_GATEWAY_URL} / ${JUDGE_GATEWAY_KEY}).
# Sem isso, o teste do Judge roda em replay de cassette (offline). Com isso,
# `pytest tests/test_judge_eval.py --live` chama o gateway real.
# ----------------------------------------------------------------------------
JUDGE_GATEWAY_URL=
JUDGE_GATEWAY_KEY=


# ----------------------------------------------------------------------------
# Step 9 — Distribuição no portfolio de contas
# (cloud phones isolados + proxies + scheduler). NÃO é uma única API — depende
# do provedor de cloud phones / proxy que você usar. Placeholders genéricos.
# [FUTURO] adapter DistributionPort
# ----------------------------------------------------------------------------
# DISTRIBUTION_PROVIDER=
# DISTRIBUTION_API_KEY=
# PROXY_POOL_URL=


# ----------------------------------------------------------------------------
# Observabilidade — LangSmith (tracing + eval do Judge)
# Tracing é automático quando estas envs estão setadas (vem de usar
# LangChain/LangGraph; nada a codar). Sem elas, roda offline.
# ----------------------------------------------------------------------------
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ugc-orchestrator
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ----------------------------------------------------------------------------
# Motor — caminhos (opcionais; têm default no código)
# ----------------------------------------------------------------------------
# ORCH_CONFIG_DIR=config
# ORCH_DB=.orchestrator/runs.sqlite
